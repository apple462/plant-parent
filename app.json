{
  "expo": {
    "name": "plant-parent",
    "slug": "plant-parent",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "plantparent",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.makingitlegendary.plantparent",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.makingitlegendary.plantparent",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-sqlite",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Plant Parent uses your location to tailor watering suggestions to your local weather."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Plant Parent accesses your photos so you can set a cover photo and identify a plant from a picture.",
          "cameraPermission": "Plant Parent uses the camera so you can photograph a plant to identify it or set its cover photo.",
          "microphonePermission": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9c50b986-e0f2-48ec-bde9-19691ef02b3f"
      },
      "plantNetApiKey": "2b10sSRtVlaodZsKHIa3ZB53m"
    },
    "owner": "apple462"
  }
}
